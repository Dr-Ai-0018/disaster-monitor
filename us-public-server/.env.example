# ============================================
# 应用基础配置
# ============================================
APP_NAME=DisasterMonitoringSystem
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=sqlite:///database/disaster.db

# ============================================
# RSOE Cookie 配置（从浏览器开发者工具获取）
# 建议直接复制浏览器「Application > Cookies > https://rsoe-edis.org」的值
# ============================================
SESSION_EDIS_WEB=brhm1mdvvraq6j1qfe3k670mpqb6pr28
ARR_AFFINITY=e5ecae1dd1d80a23c3ccdfa48505b16bb5bff8f1c835ac679c74a3d15da5f1eb
ARR_AFFINITY_SAME_SITE=e5ecae1dd1d80a23c3ccdfa48505b16bb5bff8f1c835ac679c74a3d15da5f1eb
_GA=GA1.1.865082856.1760150007
__GADS=ID=6650a0bc636c0a6a:T=1760150008:RT=1760150008:S=ALNI_MaqgqxEZLnT2LdqT5FoP5mjlyeMuA
__GPI=UID=0000129b8251a39e:T=1760150008:RT=1760150008:S=ALNI_MYuFS4O40JrskZnbaFuWs57BhoAxQ

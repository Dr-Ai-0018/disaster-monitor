_GA_KHD7YP5VHW=GS2.1.s1760150006$o1$g1$t1760150207$j30$l0$h0

# 请求间隔/超时（可根据抓取稳定性调整）
REQUEST_TIMEOUT=30
REQUEST_DELAY=1.5

# ============================================
# Google Earth Engine 配置
# ============================================
GEE_PROJECT_ID=your-gee-project-id
GEE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GEE_SERVICE_ACCOUNT_PATH=config/service_account.json

# ============================================
# OpenAI 配置（GPT-4.1-mini 质量评估）
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# ============================================
# Google Gemini 配置（日报生成）
# ============================================
GEMINI_API_KEY=your-gemini-api-key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.5-pro-preview-03-25

# ============================================
# JWT 认证配置
# ============================================
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# 启动初始化配置（管理员 / GPU Worker Token）
# ============================================
SEED_ADMIN_ENABLED=true
SEED_ADMIN_USERNAME=user-707
SEED_ADMIN_PASSWORD=srgYJKmvr953yj
SEED_ADMIN_EMAIL=0example@killerbest.com
SEED_ADMIN_FULL_NAME=System Administrator

SEED_GPU_TOKEN_ENABLED=true
SEED_GPU_TOKEN_NAME=GPU-Server-1
SEED_GPU_TOKEN_DESCRIPTION=内网GPU服务器访问令牌
SEED_GPU_TOKEN_VALUE=gpu-server-local-token

# ============================================
# 服务器配置
# ============================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4
# GPU Worker 访问卫星影像的服务器基础 URL（生产环境必须设置为公网可访问的地址）
# 示例：SERVER_BASE_URL=https://api.yourdomain.com
SERVER_BASE_URL=
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/disaster.log

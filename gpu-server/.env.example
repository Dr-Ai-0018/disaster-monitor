# ============================================
# Worker 标识
# ============================================
WORKER_ID=gpu-server-1
WORKER_NAME=内网GPU服务器1

# ============================================
# 公网 API 配置
# ============================================
# 开发环境
API_BASE_URL=http://127.0.0.1:8000
# 生产环境（部署时取消注释）
# API_BASE_URL=https://disaster-api.example.com

# GPU 服务器专用 API Token（从公网服务器创建）
API_TOKEN=your-api-token-here

# ============================================
# 模型配置
# ============================================
MODEL_NAME=disaster-recognition-v1
MODEL_VERSION=1.0.0
# 模型目录（支持 HuggingFace 路径或本地路径）
MODEL_PATH=models/disaster_model

# ============================================
# GPU 配置
# ============================================
CUDA_VISIBLE_DEVICES=0
TORCH_NUM_THREADS=4

# ============================================
# 任务轮询配置
# ============================================
POLL_INTERVAL_SECONDS=3600
HEARTBEAT_INTERVAL_SECONDS=300
MAX_TASKS_PER_PULL=5

# ============================================
# 推理配置
# ============================================
MAX_IMAGE_SIZE=1024
BATCH_SIZE=1

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/gpu_worker.log

# ============================================
# 临时目录
# ============================================
TEMP_DIR=temp
